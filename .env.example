# ─────────────────────────────────────────────
# Book Service — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/book_db"

# JWT — must use the SAME secret as auth-service
JWT_SECRET="your-super-secret-jwt-key-shared-with-auth-service"

# MinIO / S3-compatible object storage
S3_ENDPOINT="http://minio:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="books"
S3_REGION="us-east-1"

# Public base URL for generating image URLs
# If MinIO is behind a reverse proxy, use that URL instead
S3_PUBLIC_URL="http://localhost:9000"

# Server
PORT=8000
NODE_ENV="development"

# Service identity (for logs/traces)
SERVICE_NAME="book-service"
SERVICE_VERSION="1.0.0"
OTEL_EXPORTER_OTLP_ENDPOINT="http://alloy:4317"
LOKI_HOST="http://loki:3100"